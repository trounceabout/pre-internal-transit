---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sentry Test Page"
  description="Testing error tracking with Sentry"
>
  <div class="container mx-auto px-4 py-16 max-w-3xl">
    <h1 class="text-4xl font-bold mb-8">Sentry Error Tracking Test</h1>

    <p class="mb-8 text-lg text-gray-600">
      This page helps you verify that Sentry is properly capturing browser errors.
      Click any button below to test different error scenarios.
    </p>

    <div class="space-y-6">
      <!-- Test 1: Unhandled error -->
      <div class="border-2 border-red-500 p-6 rounded-lg bg-red-50">
        <h2 class="text-2xl font-bold mb-2 text-red-600">Test 1: Unhandled Error</h2>
        <p class="mb-4 text-gray-700">
          Throws an unhandled error that Sentry will automatically capture.
          This demonstrates automatic error tracking.
        </p>
        <button
          id="test-unhandled-error"
          class="bg-red-500 text-white px-6 py-3 rounded-lg hover:bg-red-600 transition-colors font-semibold"
        >
          Throw Test Error
        </button>
      </div>

      <!-- Test 2: Manually captured error -->
      <div class="border-2 border-yellow-500 p-6 rounded-lg bg-yellow-50">
        <h2 class="text-2xl font-bold mb-2 text-yellow-600">Test 2: Manually Captured Error</h2>
        <p class="mb-4 text-gray-700">
          Manually captures an error using <code class="bg-gray-200 px-2 py-1 rounded">Sentry.captureException()</code>.
          Useful for catching expected errors with custom handling.
        </p>
        <button
          id="test-manual-capture"
          class="bg-yellow-500 text-gray-900 px-6 py-3 rounded-lg hover:bg-yellow-600 transition-colors font-semibold"
        >
          Send Handled Error
        </button>
      </div>

      <!-- Test 3: Custom message -->
      <div class="border-2 border-blue-500 p-6 rounded-lg bg-blue-50">
        <h2 class="text-2xl font-bold mb-2 text-blue-600">Test 3: Custom Message</h2>
        <p class="mb-4 text-gray-700">
          Sends a custom message to Sentry without an error. Useful for logging
          important events that don't represent failures.
        </p>
        <button
          id="test-message"
          class="bg-blue-500 text-white px-6 py-3 rounded-lg hover:bg-blue-600 transition-colors font-semibold"
        >
          Send Message
        </button>
      </div>
    </div>

    <!-- Instructions Section -->
    <div class="mt-12 p-6 bg-gray-100 rounded-lg border-l-4 border-gray-400">
      <h3 class="text-xl font-bold mb-4">📋 Testing Instructions</h3>

      <div class="space-y-4">
        <div>
          <h4 class="font-semibold mb-2">🛑 Important: Local Testing</h4>
          <p class="text-gray-700 mb-2">
            Sentry is <strong>disabled in development mode</strong>
            (<code class="bg-white px-2 py-1 rounded">bun run dev</code>).
            You must build and preview to test:
          </p>
          <ol class="list-decimal list-inside space-y-1 text-gray-700 ml-4">
            <li><code class="bg-white px-2 py-1 rounded">bun run build</code> – Build the static site</li>
            <li><code class="bg-white px-2 py-1 rounded">bun run preview</code> – Start preview server</li>
            <li>Visit <code class="bg-white px-2 py-1 rounded">http://localhost:4321/test-sentry</code></li>
            <li>Click any test button</li>
            <li>Check your Sentry dashboard for new issues</li>
          </ol>
        </div>

        <div>
          <h4 class="font-semibold mb-2">⏱️ Dashboard Update Time</h4>
          <p class="text-gray-700">
            Errors appear in your Sentry dashboard within <strong>1-2 minutes</strong>.
            Visit <a href="https://sentry.io" target="_blank" class="text-blue-600 hover:underline">sentry.io</a>
            and check your project's Issues tab.
          </p>
        </div>

        <div>
          <h4 class="font-semibold mb-2">✅ Verify Success</h4>
          <p class="text-gray-700">Your error should include:</p>
          <ul class="list-disc list-inside ml-4 text-gray-700 space-y-1 mt-2">
            <li>Error message with timestamp</li>
            <li>Browser and OS information</li>
            <li>URL: <code class="bg-white px-2 py-1 rounded">/test-sentry</code></li>
            <li>Full JavaScript stack trace</li>
          </ul>
        </div>

        <div>
          <h4 class="font-semibold mb-2">🗑️ Cleanup</h4>
          <p class="text-gray-700">
            Once you've verified Sentry is working, you can delete this page
            (<code class="bg-white px-2 py-1 rounded">src/pages/test-sentry.astro</code>)
            from your repository.
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    import * as Sentry from '@sentry/astro';

    // Test 1: Unhandled error
    document.getElementById('test-unhandled-error')?.addEventListener('click', () => {
      throw new Error(`Test error thrown at ${new Date().toISOString()}`);
    });

    // Test 2: Manually captured error
    document.getElementById('test-manual-capture')?.addEventListener('click', () => {
      try {
        throw new Error(`Manually captured error at ${new Date().toISOString()}`);
      } catch (error) {
        // Manually send to Sentry with custom context
        Sentry.captureException(error, {
          tags: {
            'test_type': 'manual_capture',
          },
          extra: {
            'button_clicked': 'test-manual-capture',
          },
        });

        // Show user feedback
        alert('✅ Error sent to Sentry! Check your dashboard in 1-2 minutes.');
      }
    });

    // Test 3: Custom message
    document.getElementById('test-message')?.addEventListener('click', () => {
      Sentry.captureMessage(
        `Test message sent at ${new Date().toISOString()}`,
        'info'
      );
      alert('✅ Message sent to Sentry!');
    });
  </script>
</BaseLayout>
