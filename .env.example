# Internal Transit Website Environment Variables

# Buttondown Newsletter Configuration
PUBLIC_BUTTONDOWN_USERNAME=your_buttondown_username

# Site Configuration
PUBLIC_SITE_URL=https://yourdomain.com

# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/[your-org]/projects/[your-project]/keys/
# This is a PUBLIC key - it's safe to include in browser code and Vercel env vars
PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0